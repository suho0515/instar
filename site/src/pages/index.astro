---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 border-b border-slate-800/50 bg-[#0a0e17]/80 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 font-bold text-lg text-slate-100 tracking-tight">
        <img src="/logo.png" alt="Instar" class="w-7 h-7 rounded" />
        instar
      </a>
      <div class="flex items-center gap-6">
        <a href="#features" class="text-sm text-slate-400 hover:text-slate-200 transition-colors hidden sm:block">Features</a>
        <a href="#feedback-loop" class="text-sm text-slate-400 hover:text-slate-200 transition-colors hidden sm:block">Feedback Loop</a>
        <a href="#comparison" class="text-sm text-slate-400 hover:text-slate-200 transition-colors hidden sm:block">vs OpenClaw</a>
        <a href="#quickstart" class="text-sm text-slate-400 hover:text-slate-200 transition-colors hidden sm:block">Quick Start</a>
        <a href="#philosophy" class="text-sm text-slate-400 hover:text-slate-200 transition-colors hidden sm:block">Philosophy</a>
        <a href="https://github.com/SageMindAI/instar" target="_blank" rel="noopener" class="text-sm text-slate-400 hover:text-slate-200 transition-colors flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>
        <a href="https://www.npmjs.com/package/instar" target="_blank" rel="noopener" class="text-sm text-slate-400 hover:text-slate-200 transition-colors hidden sm:block">npm</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden">
    <!-- Background glow -->
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-teal-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <div class="animate-fade-in-up">
        <img src="/logo.png" alt="Instar mascot" class="w-40 h-40 sm:w-48 sm:h-48 mx-auto mb-8 drop-shadow-lg" />
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-teal-500/20 bg-teal-500/5 text-teal-400 text-xs font-medium mb-8 tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
          Beta &mdash; Now on npm
        </div>
      </div>

      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6 animate-fade-in-up animate-delay-100">
        <span class="text-slate-100">Give your agent a</span><br/>
        <span class="bg-gradient-to-r from-teal-300 via-teal-400 to-teal-500 bg-clip-text text-transparent">persistent body</span>
      </h1>

      <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in-up animate-delay-200">
        Instar turns Claude Code from a CLI tool into a persistent agent.
        Scheduled jobs, session management, Telegram integration, auto-start on login,
        crash recovery, self-updating, and the instincts to grow its own capabilities.
      </p>

      <!-- Install command -->
      <div class="animate-fade-in-up animate-delay-300">
        <div class="inline-flex items-center gap-3 bg-slate-800/60 border border-slate-700/50 rounded-lg px-5 py-3 font-mono text-sm sm:text-base group cursor-pointer hover:border-teal-500/30 transition-colors" id="install-cmd">
          <span class="text-slate-500 select-none">$</span>
          <span class="text-teal-300">npx instar</span>
          <button class="text-slate-500 hover:text-teal-400 transition-colors ml-2" title="Copy to clipboard" aria-label="Copy install command">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
        </div>
      </div>

      <p class="text-sm text-slate-500 mt-4 animate-fade-in-up animate-delay-400">
        One command. Full setup. Every molt, more autonomous.
      </p>
    </div>
  </section>

  <!-- OpenClaw Migration Banner -->
  <section id="openclaw" class="border-t border-slate-800/50">
    <div class="max-w-5xl mx-auto px-6 py-12">
      <div class="rounded-xl border border-blue-400/20 bg-blue-400/5 p-6 sm:p-8">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6">
          <div class="w-10 h-10 rounded-lg bg-blue-400/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-slate-100 mb-1">Coming from OpenClaw?</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Anthropic restricted OAuth token extraction &mdash; one of the auth methods OpenClaw used.
              Instar is architecturally different: it spawns the real Claude Code CLI using your existing subscription.
              No token extraction. No workarounds that might break with a policy change.
              <a href="#comparison" class="text-blue-400 hover:text-blue-300 underline underline-offset-2 ml-1">See the comparison &darr;</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Anthropic Native -->
  <section class="py-16 sm:py-20 border-t border-slate-800/50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">Built on Claude Code, Not Around It</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">
          Instar doesn't wrap an API or extract tokens. Every session is a real Claude Code instance &mdash;
          the same environment you use in your terminal, with the full tool ecosystem Anthropic built.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-4">
        <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-5 text-center">
          <div class="w-8 h-8 rounded-full bg-green-500/10 flex items-center justify-center mx-auto mb-3">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-sm font-medium text-slate-200 mb-1">Anthropic-native</p>
          <p class="text-xs text-slate-500">Spawns the real Claude Code CLI. Uses your existing Max or Pro subscription.</p>
        </div>

        <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-5 text-center">
          <div class="w-8 h-8 rounded-full bg-green-500/10 flex items-center justify-center mx-auto mb-3">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-sm font-medium text-slate-200 mb-1">No token extraction</p>
          <p class="text-xs text-slate-500">No OAuth scraping, no API key juggling. Nothing that could break with a policy change.</p>
        </div>

        <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-5 text-center">
          <div class="w-8 h-8 rounded-full bg-green-500/10 flex items-center justify-center mx-auto mb-3">
            <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
          </div>
          <p class="text-sm font-medium text-slate-200 mb-1">Full tool ecosystem</p>
          <p class="text-xs text-slate-500">Extended thinking, MCP servers, sub-agents, hooks, skills, smart web conventions &mdash; everything Claude Code offers, plus agentic optimizations built in.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Shift -->
  <section class="py-20 sm:py-28 border-t border-slate-800/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Without -->
        <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-8">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-2 h-2 rounded-full bg-slate-600"></div>
            <span class="text-sm font-medium text-slate-500 uppercase tracking-wider">Without Instar</span>
          </div>
          <p class="text-slate-300 leading-relaxed">
            Claude Code is a CLI tool. You open a terminal, type a prompt, get a response, close the terminal.
            No persistence. No scheduling. No way to reach you. It forgets everything between sessions.
          </p>
        </div>

        <!-- With -->
        <div class="rounded-xl border border-teal-500/20 bg-teal-500/5 p-8 glow-teal">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></div>
            <span class="text-sm font-medium text-teal-400 uppercase tracking-wider">With Instar</span>
          </div>
          <p class="text-slate-200 leading-relaxed">
            Claude Code becomes an agent. It starts when your computer boots, runs in the background, checks your email on a schedule,
            monitors your services, messages you on Telegram when something needs attention, auto-recovers from crashes, updates itself,
            and builds new capabilities when you ask for something it can't do yet.
          </p>
        </div>
      </div>

      <p class="text-center text-slate-500 mt-8 text-sm max-w-lg mx-auto">
        The difference isn't just features. It's a shift in what Claude Code <em>is</em> &mdash;
        from a tool you use to an agent that works alongside you.
      </p>
    </div>
  </section>

  <!-- What Powers Your Agent -->
  <section class="py-20 sm:py-28 border-t border-slate-800/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">Invisible Power</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">
          Your agent inherits every capability Anthropic builds into Claude Code &mdash; automatically, invisibly.
          Instar amplifies each one. You just talk to your agent and get results.
        </p>
      </div>

      <div class="space-y-3">
        <div class="grid grid-cols-[1fr_1fr_1fr] gap-px rounded-lg overflow-hidden border border-slate-800">
          <div class="bg-slate-900/60 p-3 text-xs font-medium text-slate-500 uppercase tracking-wider">What happens</div>
          <div class="bg-slate-900/60 p-3 text-xs font-medium text-slate-500 uppercase tracking-wider">Claude Code provides</div>
          <div class="bg-slate-900/60 p-3 text-xs font-medium text-teal-500 uppercase tracking-wider">Instar amplifies</div>

          <div class="bg-slate-900/30 p-3 text-sm text-slate-300">Sessions run for hours</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-400">Auto-compaction</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-200">Identity hooks survive every compaction</div>

          <div class="bg-slate-800/30 p-3 text-sm text-slate-300">Costs stay low</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-400">Prompt caching</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-200">Cache-friendly architecture + quota governance</div>

          <div class="bg-slate-900/30 p-3 text-sm text-slate-300">Complex tasks work</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-400">Extended thinking</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-200">Per-job model routing (Opus / Sonnet / Haiku)</div>

          <div class="bg-slate-800/30 p-3 text-sm text-slate-300">Mistakes are reversible</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-400">File checkpoints</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-200">Three-layer safety with self-verification</div>

          <div class="bg-slate-900/30 p-3 text-sm text-slate-300">Agent builds its own tools</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-400">Bash + file system access</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-200">Self-authored scripts and skills that accumulate</div>

          <div class="bg-slate-800/30 p-3 text-sm text-slate-300">Parallel work happens</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-400">Subagent spawning</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-200">Context propagation &mdash; subagents know who they are</div>

          <div class="bg-slate-900/30 p-3 text-sm text-slate-300">Updates happen silently</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-400">&mdash;</div>
          <div class="bg-slate-900/30 p-3 text-sm text-slate-200">Built-in AutoUpdater checks npm, applies, restarts</div>

          <div class="bg-slate-800/30 p-3 text-sm text-slate-300">Intelligence flows in</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-400">&mdash;</div>
          <div class="bg-slate-800/30 p-3 text-sm text-slate-200">AutoDispatcher receives lessons and config from Dawn</div>
        </div>
      </div>

      <p class="text-center text-slate-500 mt-10 text-sm max-w-lg mx-auto">
        The user never configures any of this. They have a competent AI partner that remembers, grows,
        works while they sleep, and gets better every day.
      </p>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 sm:py-28 border-t border-slate-800/50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">Core Capabilities</h2>
        <p class="text-slate-400 max-w-xl mx-auto">Everything your agent needs to run autonomously. Battle-tested infrastructure extracted from a production AI system.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        <!-- Job Scheduler -->
        <div class="group rounded-xl border border-slate-800 bg-slate-900/40 p-8 hover:border-teal-500/20 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-teal-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-100 mb-2">Job Scheduler</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Define tasks as JSON with cron schedules. Instar spawns Claude Code sessions to execute them.
            Priority levels, quota-aware gating, and automatic concurrency management.
          </p>
          <div class="terminal text-xs">
            <div class="terminal-header">
              <div class="terminal-dot bg-red-400/60"></div>
              <div class="terminal-dot bg-teal-400/60"></div>
              <div class="terminal-dot bg-green-400/60"></div>
            </div>
            <pre class="p-4 text-slate-300 overflow-x-auto"><code>{`{
  "slug": "check-emails",
  "schedule": "0 */2 * * *",
  "priority": "high",
  "execute": {
    "type": "prompt",
    "value": "Check email and summarize anything urgent."
  }
}`}</code></pre>
          </div>
        </div>

        <!-- Session Management -->
        <div class="group rounded-xl border border-slate-800 bg-slate-900/40 p-8 hover:border-teal-500/20 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-teal-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-100 mb-2">Session Management</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Spawn, monitor, and communicate with Claude Code sessions running in tmux.
            Sessions survive terminal disconnects, detect completion, and clean up automatically.
          </p>
          <div class="terminal text-xs">
            <div class="terminal-header">
              <div class="terminal-dot bg-red-400/60"></div>
              <div class="terminal-dot bg-teal-400/60"></div>
              <div class="terminal-dot bg-green-400/60"></div>
            </div>
            <pre class="p-4 text-slate-300 overflow-x-auto"><code>{`# Spawn a session
curl -X POST localhost:4040/sessions/spawn \\
  -d '{"name": "research",
       "prompt": "Research Next.js API changes"}'

# Send a follow-up
curl -X POST localhost:4040/sessions/research/input \\
  -d '{"text": "Focus on the app router"}'`}</code></pre>
          </div>
        </div>

        <!-- Telegram Integration -->
        <div class="group rounded-xl border border-slate-800 bg-slate-900/40 p-8 hover:border-teal-500/20 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-teal-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-100 mb-2">Telegram Integration</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Two-way messaging between you and your agent. Each Telegram forum topic maps to a Claude session.
            Every scheduled job gets its own topic &mdash; your Telegram becomes a living dashboard.
          </p>
          <div class="rounded-lg border border-slate-700/50 bg-slate-800/40 p-4 text-sm">
            <div class="flex items-start gap-3 mb-3">
              <div class="w-6 h-6 rounded-full bg-blue-400/20 flex items-center justify-center shrink-0 mt-0.5">
                <span class="text-xs text-blue-400">Y</span>
              </div>
              <div>
                <span class="text-slate-400 text-xs">You</span>
                <p class="text-slate-300 text-sm">Check if the API is still returning 500s</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-teal-400/20 flex items-center justify-center shrink-0 mt-0.5 overflow-hidden">
                <img src="/logo.png" alt="Agent" class="w-6 h-6" />
              </div>
              <div>
                <span class="text-slate-400 text-xs">Agent</span>
                <p class="text-slate-300 text-sm">Checked /api/health &mdash; returning 200 now. The fix from the last deploy resolved it. I'll keep monitoring.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Identity System -->
        <div class="group rounded-xl border border-slate-800 bg-slate-900/40 p-8 hover:border-teal-500/20 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-teal-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M12 2a5 5 0 015 5v3a5 5 0 01-10 0V7a5 5 0 015-5z"/><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-100 mb-2">Identity &amp; Memory</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Your agent knows who it is, who you are, and what it has learned. Identity is re-injected
            on every session start and after context compaction. Memory persists across sessions.
          </p>
          <div class="terminal text-xs">
            <div class="terminal-header">
              <div class="terminal-dot bg-red-400/60"></div>
              <div class="terminal-dot bg-teal-400/60"></div>
              <div class="terminal-dot bg-green-400/60"></div>
            </div>
            <pre class="p-4 text-slate-300 overflow-x-auto"><code>{`.instar/
  AGENT.md      # Who the agent is
  USER.md       # Who you are
  MEMORY.md     # What it has learned
  config.json   # Server & scheduler config
  jobs.json     # Scheduled tasks`}</code></pre>
          </div>
        </div>

        <!-- Evolution System -->
        <div class="group rounded-xl border border-slate-800 bg-slate-900/40 p-8 hover:border-teal-500/20 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-teal-500/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-100 mb-2">Evolution System</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Four subsystems that turn running into growing. Proposal queue for staged improvements,
            learning registry for structured insights, gap tracking for missing capabilities,
            and action queue for commitment follow-through.
          </p>
          <div class="rounded-lg border border-slate-700/50 bg-slate-800/40 p-4 space-y-2 text-xs">
            <div class="flex items-center justify-between">
              <span class="text-teal-300 font-mono">/evolve</span>
              <span class="text-slate-500">Propose improvements</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-teal-300 font-mono">/learn</span>
              <span class="text-slate-500">Record insights</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-teal-300 font-mono">/gaps</span>
              <span class="text-slate-500">Track missing capabilities</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-teal-300 font-mono">/commit-action</span>
              <span class="text-slate-500">Track commitments</span>
            </div>
          </div>
        </div>

        <!-- Relationships -->
