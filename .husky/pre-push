# ── Fast gate: catch NEXT.md / version issues before the 4-min test suite ──
echo "🔒 Running pre-push gate (NEXT.md + version check)..."
if ! node scripts/pre-push-gate.js; then
  exit 1
fi

echo "🧪 Running test suite before push (excludes known flaky tests)..."
echo "   Full suite: npm test | Flaky only: npm run test:flaky"

# Try up to 2 times — flaky tests may fail intermittently
for attempt in 1 2; do
  if npm run test:push; then
    exit 0
  fi
  if [ "$attempt" -eq 1 ]; then
    echo ""
    echo "⚠️  Attempt 1 failed — retrying once (intermittent failures suspected)..."
    echo ""
  fi
done

echo "❌ Tests failed on both attempts. Run 'npm run test:push' to debug."
exit 1
