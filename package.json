{
  "name": "instar",
  "version": "0.12.24",
  "description": "Persistent autonomy infrastructure for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "instar": "dist/cli.js"
  },
  "scripts": {
    "generate:manifest": "node scripts/generate-builtin-manifest.cjs",
    "build": "node scripts/generate-builtin-manifest.cjs && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts && vitest run --config vitest.e2e.config.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "check:upgrade-guide": "node scripts/check-upgrade-guide.js",
    "prepublishOnly": "npm run build && npm run check:upgrade-guide",
    "prepare": "husky"
  },
  "keywords": [
    "instar",
    "autonomous",
    "agent",
    "molt",
    "lobster",
    "claude",
    "cli",
    "automation",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SageMindAI/instar.git"
  },
  "bugs": {
    "url": "https://github.com/SageMindAI/instar/issues"
  },
  "homepage": "https://instar.sh",
  "files": [
    "dist",
    "dashboard",
    "upgrades",
    "src/templates",
    "src/data",
    "playbook-scripts",
    ".claude/skills/setup-wizard",
    ".claude/skills/secret-setup",
    ".claude/hooks",
    ".claude/settings.json"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@inquirer/prompts": "^8.2.1",
    "better-sqlite3": "^12.6.2",
    "cloudflared": "^0.7.1",
    "commander": "^12.0.0",
    "croner": "^8.0.0",
    "express": "^4.18.0",
    "picocolors": "^1.0.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.19.0"
  },
  "peerDependencies": {
    "@whiskeysockets/baileys": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@whiskeysockets/baileys": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
