{
  "name": "instar",
  "version": "0.8.23",
  "description": "Persistent autonomy infrastructure for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "instar": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts && vitest run --config vitest.e2e.config.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "instar",
    "autonomous",
    "agent",
    "molt",
    "lobster",
    "claude",
    "cli",
    "automation",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SageMindAI/instar.git"
  },
  "bugs": {
    "url": "https://github.com/SageMindAI/instar/issues"
  },
  "homepage": "https://instar.sh",
  "files": [
    "dist",
    "dashboard",
    "upgrades"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "cloudflared": "^0.7.1",
    "commander": "^12.0.0",
    "croner": "^8.0.0",
    "express": "^4.18.0",
    "picocolors": "^1.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
